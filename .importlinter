[importlinter]
root_package = application
include_external_packages = False

[importlinter:contract:hexagonal_layers]
name = Hexagonal layers depend inward only
type = layers
layers =
    application.entrypoints
    application.infrastructure
    application.adapters
    application.application
    application.ports
    application.domain

[importlinter:contract:incoming_outgoing_adapter_separation]
name = Incoming adapters must not import outgoing adapters
type = forbidden
source_modules =
    application.adapters.incoming
forbidden_modules =
    application.adapters.outgoing

[importlinter:contract:outgoing_incoming_adapter_separation]
name = Outgoing adapters must not import incoming adapters
type = forbidden
source_modules =
    application.adapters.outgoing
forbidden_modules =
    application.adapters.incoming

[importlinter:contract:domain_must_not_import_outer_layers]
name = Domain must not import application adapters or infrastructure
type = forbidden
source_modules =
    application.domain
forbidden_modules =
    application.application
    application.adapters
    application.infrastructure

[importlinter:contract:ports_must_not_import_application_or_technical_layers]
name = Ports must not import application adapters or infrastructure
type = forbidden
source_modules =
    application.ports
forbidden_modules =
    application.application
    application.adapters
    application.infrastructure

[importlinter:contract:application_must_not_import_adapters_or_infrastructure]
name = Application must not import adapters or infrastructure directly
type = forbidden
source_modules =
    application.application
forbidden_modules =
    application.adapters
    application.infrastructure

[importlinter:contract:outgoing_adapters_must_not_import_application]
name = Outgoing adapters must not depend on application orchestration
type = forbidden
source_modules =
    application.adapters.outgoing
forbidden_modules =
    application.application
